# ─── Runtime ────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
TIMEZONE=Europe/Berlin

# ─── Database ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pantra:pantra@localhost:5432/pantra
DATABASE_URL_SYNC=postgresql+psycopg2://pantra:pantra@localhost:5432/pantra

# ─── Redis / Celery ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── WhatsApp (Meta Cloud API) ──────────────────────────────────────────
# Provider: 'cloud_api' (Meta direct) or '360dialog'
WHATSAPP_PROVIDER=cloud_api
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=change-me-handshake-token
WHATSAPP_APP_SECRET=change-me-app-secret
WHATSAPP_API_BASE=https://graph.facebook.com/v21.0

# ─── LLM ────────────────────────────────────────────────────────────────
# Models are env-driven — never hardcoded.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

LLM_CLASSIFIER_PROVIDER=anthropic
LLM_CLASSIFIER_MODEL=claude-haiku-4-5-20251001

LLM_MAIN_PROVIDER=anthropic
LLM_MAIN_MODEL=claude-sonnet-4-6
LLM_MAIN_MAX_TOKENS=1024
LLM_MAIN_TEMPERATURE=0.4

# ─── Memory ─────────────────────────────────────────────────────────────
MEMORY_WINDOW_MESSAGES=20
MEMORY_SUMMARIZE_AFTER=40

# ─── Handoff ────────────────────────────────────────────────────────────
# Telegram bot for the business owner (created via @BotFather).
# TELEGRAM_CHAT_ID is the owner's chat with the bot — see /getUpdates after
# the owner sends /start.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_API_BASE=https://api.telegram.org

HANDOFF_EMAIL_TO=
HANDOFF_EMAIL_FROM=pantra@example.com

EMAIL_PROVIDER=resend
RESEND_API_KEY=

# ─── Audio (STT + TTS) ──────────────────────────────────────────────────
# Whisper STT uses OPENAI_API_KEY above.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_API_BASE=https://api.elevenlabs.io/v1

AUDIO_STORAGE_PATH=./storage/audio
AUDIO_RETENTION_HOURS=24
# REQUIRED for WhatsApp outbound audio. Meta needs an HTTPS URL it can fetch.
# Dev: tunnel via ngrok, e.g. https://abc123.ngrok.app/static/audio
# Prod: https://app.pantra.com/static/audio
AUDIO_PUBLIC_URL_BASE=

# tts_default_mode: text_only | mirror | audio_always
TTS_DEFAULT_MODE=mirror

# ─── Demo ───────────────────────────────────────────────────────────────
# Optional: separate Telegram chat for demo handoffs (keeps prospect tests
# out of the prod owner's notifications). Empty = demo handoffs logged only.
DEMO_HANDOFF_TELEGRAM_CHAT_ID=
DEMO_SESSION_DAYS=7

# ─── Privacy ────────────────────────────────────────────────────────────
PII_REDACTION_ENABLED=true
LOG_RETENTION_DAYS=7

# ─── Google Calendar ────────────────────────────────────────────────────
GOOGLE_CALENDAR_CLIENT_EMAIL=
GOOGLE_CALENDAR_PRIVATE_KEY=
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar
