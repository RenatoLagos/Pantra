      <input class="form-input-on-sage" type="text" name="contact_name" placeholder="Name *" required>
      <input class="form-input-on-sage" type="text" name="clinic_name" placeholder="Praxisname *" required>
      <input class="form-input-on-sage" type="email" name="email" placeholder="Business E-Mail *" required>
      <input class="form-input-on-sage" type="tel" name="phone" placeholder="Telefon (optional)">

      <label class="form-checkbox-row">
        <input type="checkbox" name="consent_dsgvo" required>
        <span>
          <!-- TRANSLATE-DE: Ich stimme der Verarbeitung meiner Daten gemäß
                            <a href="/datenschutz">Datenschutzerklärung</a> zu. -->
          Acepto el procesamiento de mis datos según la
          <a href="/datenschutz">política de privacidad</a>.
        </span>
      </label>

      <button type="submit" class="btn-light-pill">
        <!-- TRANSLATE-DE: 14 Tage kostenlos starten -->
        Iniciar 14 días gratis
      </button>

      <div class="form-status" id="form-status"></div>
    </form>
  </div>
</section>

{# Inline form-handling JS — tiny, no framework. Submits via fetch and shows
   inline status. Falls back to native submit if JS is disabled. #}
<script>
(function() {
  const form = document.getElementById('trial-form');
  if (!form) return;
  const status = document.getElementById('form-status');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    status.className = 'form-status';
    status.textContent = '';

    const data = Object.fromEntries(new FormData(form));
    data.consent_dsgvo = !!data.consent_dsgvo;
    data.source = 'einzelpraxis';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (res.ok) {
        status.className = 'form-status success';
        status.textContent = 'Danke! Wir melden uns innerhalb von 24 Stunden bei Ihnen.';
        form.reset();
      } else {
        const err = await res.json().catch(() => ({}));
        status.className = 'form-status error';
        status.textContent = err.detail || 'Etwas ist schiefgelaufen. Bitte erneut versuchen.';
      }
    } catch (err) {
      status.className = 'form-status error';
      status.textContent = 'Netzwerkfehler. Bitte erneut versuchen.';
    }
  });
})();
</script>

{% endblock %}
