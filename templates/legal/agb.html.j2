      </li>
      <li>
        <!-- TRANSLATE-DE: <strong>Server in Frankfurt</strong> (AWS eu-central-1) -->
        <strong>Servidores en Frankfurt</strong> (AWS eu-central-1)
      </li>
      <li>
        <!-- TRANSLATE-DE: <strong>Monatliche Kündigung</strong> ohne Bindung -->
        <strong>Cancelación mensual</strong> sin compromiso
      </li>
      <li>
        <!-- TRANSLATE-DE: <strong>Klare Preisstruktur</strong> — feste
                          monatliche Gebühr, transparente Überschreitung
                          (€0,15 / Konversation) -->
