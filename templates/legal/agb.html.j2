{% extends "landing/_base.html.j2" %}

{% block title %}AGB — Allgemeine Geschäftsbedingungen — Pantra{% endblock %}
{% block meta_description %}Allgemeine Geschäftsbedingungen (AGB) von Pantra für die Nutzung des KI-Assistenten in Zahnarztpraxen.{% endblock %}

{% block content %}

<section class="legal-page">
  <div class="legal-content">

    <div class="legal-eyebrow">
      <!-- TRANSLATE-DE: Rechtliches -->
      Recht
    </div>
    <h1>
      <!-- TRANSLATE-DE: Allgemeine Geschäftsbedingungen -->
      AGB — Términos y Condiciones
    </h1>

    <div class="legal-banner">
      <div class="legal-banner-title">
        <!-- TRANSLATE-DE: In Vorbereitung -->
        En preparación
      </div>
      <p>
        <!-- TRANSLATE-DE: Unsere AGB werden derzeit gemeinsam mit unserem
