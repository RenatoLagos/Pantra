{% extends "landing/_base.html.j2" %}

{% block title %}Impressum — Pantra{% endblock %}
{% block meta_description %}Impressum von Pantra gemäß § 5 TMG.{% endblock %}

{% block content %}

<section class="legal-page">
  <div class="legal-content">

    <div class="legal-eyebrow">
      <!-- TRANSLATE-DE: Rechtliches -->
      Recht
    </div>
    <h1>Impressum</h1>

    <div class="legal-banner">
      <div class="legal-banner-title">
        <!-- TRANSLATE-DE: Hinweis -->
        Estado actual
      </div>
      <p>
        <!-- TRANSLATE-DE: Dieses Impressum wird mit der finalen Eintragung
                          unserer Geschäftsentity (UG / GmbH) aktualisiert. Die
                          vollständige Fassung gemäß § 5 TMG folgt in Kürze. -->
        Este Impressum se actualizará con la inscripción definitiva de
        nuestra entidad jurídica (UG / GmbH). La versión completa según
        § 5 TMG llegará en breve.
      </p>
    </div>

    <h2>
      <!-- TRANSLATE-DE: Anbieter / Diensteanbieter -->
      Proveedor del servicio
    </h2>

    <div class="legal-info-table">
      <div class="legal-info-row">
        <div class="legal-info-key">
          <!-- TRANSLATE-DE: Name -->
          Nombre
        </div>
        <div class="legal-info-val">Pantra (en proceso de constitución)</div>
      </div>
      <div class="legal-info-row">
        <div class="legal-info-key">
          <!-- TRANSLATE-DE: Inhaber -->
          Inhaber
        </div>
        <div class="legal-info-val">Renato Lagos</div>
      </div>
      <div class="legal-info-row">
        <div class="legal-info-key">
          <!-- TRANSLATE-DE: Anschrift -->
          Dirección
        </div>
        <div class="legal-info-val">
          <!-- TRANSLATE-DE: Pflichtangabe gemäß § 5 TMG. Wird mit
                            Geschäftseintragung ergänzt. -->
          Berlin, Deutschland<br>
          <em>(Dirección completa pendiente de inscripción)</em>
        </div>
      </div>
      <div class="legal-info-row">
        <div class="legal-info-key">Email</div>
        <div class="legal-info-val">
          <a href="mailto:hallo@pantra.de">hallo@pantra.de</a>
        </div>
      </div>
      <div class="legal-info-row">
        <div class="legal-info-key">
          <!-- TRANSLATE-DE: Telefon -->
          Teléfono
        </div>
        <div class="legal-info-val">
          <em>(Wird ergänzt)</em>
        </div>
      </div>
    </div>

    <h2>
      <!-- TRANSLATE-DE: Verantwortlich für den Inhalt nach § 55 Abs. 2 RStV -->
      Responsable del contenido según § 55 Abs. 2 RStV
    </h2>
    <p>
      Renato Lagos<br>
      <!-- TRANSLATE-DE: Anschrift wie oben. -->
      Dirección como arriba.
    </p>

    <h2>
      <!-- TRANSLATE-DE: Streitbeilegung -->
      Resolución de disputas
    </h2>
    <p>
      <!-- TRANSLATE-DE: Die Europäische Kommission stellt eine Plattform zur
                        Online-Streitbeilegung (OS) bereit:
                        https://ec.europa.eu/consumers/odr/. Wir sind nicht
                        bereit oder verpflichtet, an Streitbeilegungsverfahren
                        vor einer Verbraucherschlichtungsstelle teilzunehmen. -->
