{% extends "landing/_base.html.j2" %}

{% block title %}Datenschutzerklärung — Pantra{% endblock %}
{% block meta_description %}Datenschutzerklärung von Pantra — Verarbeitung personenbezogener Daten gemäß DSGVO.{% endblock %}

{% block content %}

<section class="legal-page">
  <div class="legal-content">

    <div class="legal-eyebrow">
      <!-- TRANSLATE-DE: Rechtliches -->
      Recht
    </div>
    <h1>Datenschutzerklärung</h1>

    <div class="legal-banner">
      <div class="legal-banner-title">
        <!-- TRANSLATE-DE: Hinweis zur aktuellen Fassung -->
        Estado actual
      </div>
      <p>
        <!-- TRANSLATE-DE: Diese Datenschutzerklärung wird derzeit von unserem
                          deutschen Datenschutz-Anwalt finalisiert. Die finale,
                          rechtsverbindliche Fassung wird vor dem ersten zahlenden
                          Kunden hier veröffentlicht. Bei dringenden Fragen zur
                          Datenverarbeitung kontaktieren Sie uns bitte direkt
                          unter datenschutz@pantra.de. -->
        Esta Datenschutzerklärung está siendo finalizada por nuestro abogado
        alemán especializado en DSGVO. La versión final y legalmente vinculante
        se publicará aquí antes del primer cliente pagante. Para preguntas
        urgentes sobre procesamiento de datos: <a href="mailto:datenschutz@pantra.de">datenschutz@pantra.de</a>.
      </p>
    </div>

    <h2>
      <!-- TRANSLATE-DE: Verantwortlicher -->
      Responsable del tratamiento
    </h2>
    <p>
      <!-- TRANSLATE-DE: Verantwortlich für die Verarbeitung personenbezogener
                        Daten im Sinne der DSGVO ist: -->
      Responsable del procesamiento de datos personales según DSGVO:
    </p>

    <div class="legal-info-table">
      <div class="legal-info-row">
        <div class="legal-info-key">
          <!-- TRANSLATE-DE: Unternehmen -->
          Empresa
        </div>
        <div class="legal-info-val">Pantra (en proceso de constitución)</div>
      </div>
      <div class="legal-info-row">
        <div class="legal-info-key">
          <!-- TRANSLATE-DE: Geschäftsführer -->
          Inhaber / Geschäftsführer
        </div>
        <div class="legal-info-val">Renato Lagos</div>
      </div>
      <div class="legal-info-row">
        <div class="legal-info-key">Email</div>
        <div class="legal-info-val">
          <a href="mailto:datenschutz@pantra.de">datenschutz@pantra.de</a>
        </div>
      </div>
      <div class="legal-info-row">
        <div class="legal-info-key">
          <!-- TRANSLATE-DE: Sitz / Adresse -->
          Sede
        </div>
        <div class="legal-info-val">Berlin, Deutschland</div>
      </div>
    </div>

    <h2>
      <!-- TRANSLATE-DE: Welche Daten verarbeitet Pantra? -->
      ¿Qué datos procesa Pantra?
    </h2>
    <p>
      <!-- TRANSLATE-DE: Pantra ist ein KI-Assistent für Zahnarztpraxen.
                        Wir verarbeiten Daten ausschließlich im Auftrag der
                        jeweiligen Praxis (Auftragsverarbeitung gemäß Art. 28
                        DSGVO). Konkret: -->
      Pantra es un asistente de IA para clínicas dentales. Procesamos datos
      exclusivamente en nombre de cada clínica (Auftragsverarbeitung según
      Art. 28 DSGVO). En concreto:
    </p>
    <ul>
      <li>
        <!-- TRANSLATE-DE: WhatsApp-Nachrichten zwischen Patient:innen und der Praxis -->
        Mensajes de WhatsApp entre pacientes y la clínica
      </li>
      <li>
        <!-- TRANSLATE-DE: Termin-Buchungen (Datum, Uhrzeit, Service) -->
        Reserva de turnos (fecha, hora, servicio)
      </li>
      <li>
        <!-- TRANSLATE-DE: Sprachnachrichten (zur Transkription) — automatisch
                          nach 24 Stunden gelöscht -->
        Mensajes de voz (para transcripción) — borrados automáticamente a las 24 horas
      </li>
      <li>
        <!-- TRANSLATE-DE: Kontaktinformationen, die der Patient selbst mitteilt
                          (Telefon, Name) -->
        Información de contacto que el paciente comparte voluntariamente
      </li>
    </ul>

    <h2>
      <!-- TRANSLATE-DE: Wo werden die Daten gespeichert? -->
      ¿Dónde se almacenan los datos?
    </h2>
    <p>
      <!-- TRANSLATE-DE: Auf Servern in Frankfurt am Main (AWS eu-central-1).
                        Patientendaten verlassen die EU für die Hauptverarbeitung
                        nicht. Bestimmte Teilverarbeitungen (z. B. KI-Antworten
                        durch Anthropic Claude) werden über zertifizierte
                        Subunternehmer durchgeführt; weitere Details werden in
                        der finalen Fassung dokumentiert. -->
      En servidores en Frankfurt (AWS eu-central-1). Los datos del paciente
      no salen de la UE para el procesamiento principal. Algunos sub-procesos
      (ej: respuestas IA por Anthropic Claude) se realizan vía sub-procesadores
      certificados; detalles completos en la versión final.
    </p>

    <h2>
      <!-- TRANSLATE-DE: Ihre Rechte als Betroffene:r -->
      Tus derechos como afectado/a
    </h2>
    <p>
      <!-- TRANSLATE-DE: Gemäß Art. 15-22 DSGVO haben Sie unter anderem das
                        Recht auf: -->
      Según los Art. 15-22 DSGVO tenés, entre otros, derecho a:
    </p>
    <ul>
      <li>
        <!-- TRANSLATE-DE: Auskunft über Ihre verarbeiteten Daten (Art. 15) -->
        Información sobre los datos procesados (Art. 15)
      </li>
      <li>
        <!-- TRANSLATE-DE: Berichtigung unrichtiger Daten (Art. 16) -->
        Rectificación de datos incorrectos (Art. 16)
      </li>
      <li>
        <!-- TRANSLATE-DE: Löschung Ihrer Daten (Art. 17, "Recht auf Vergessenwerden") -->
        Borrado de tus datos (Art. 17, "derecho al olvido")
      </li>
      <li>
        <!-- TRANSLATE-DE: Einschränkung der Verarbeitung (Art. 18) -->
        Limitación del procesamiento (Art. 18)
      </li>
      <li>
        <!-- TRANSLATE-DE: Datenübertragbarkeit (Art. 20) -->
        Portabilidad de datos (Art. 20)
      </li>
      <li>
        <!-- TRANSLATE-DE: Widerspruch gegen die Verarbeitung (Art. 21) -->
        Oposición al procesamiento (Art. 21)
      </li>
    </ul>
    <p>
      <!-- TRANSLATE-DE: Wenden Sie sich für die Ausübung dieser Rechte direkt
                        an die behandelnde Praxis (Verantwortliche) oder an
                        uns als Auftragsverarbeiter: -->
      Para ejercer estos derechos contactá directamente a la clínica
      (responsable del tratamiento) o a nosotros como encargado:
      <a href="mailto:datenschutz@pantra.de">datenschutz@pantra.de</a>.
    </p>

    <h2>
      <!-- TRANSLATE-DE: Beschwerderecht -->
      Derecho a reclamación
    </h2>
    <p>
      <!-- TRANSLATE-DE: Sie haben das Recht, sich bei der zuständigen
                        Aufsichtsbehörde zu beschweren. Für Berlin ist das: -->
      Tenés derecho a presentar una reclamación ante la autoridad de control
      competente. Para Berlin:
    </p>
    <p>
      <strong>Berliner Beauftragte für Datenschutz und Informationsfreiheit</strong><br>
      Friedrichstr. 219, 10969 Berlin<br>
      <a href="https://www.datenschutz-berlin.de" target="_blank" rel="noopener">www.datenschutz-berlin.de</a>
    </p>

    <div class="legal-meta">
      <!-- TRANSLATE-DE: Letzte Aktualisierung: -->
      Última actualización: 2026-05-08 · Placeholder, pendiente revisión legal final
    </div>

  </div>
</section>

{% endblock %}
